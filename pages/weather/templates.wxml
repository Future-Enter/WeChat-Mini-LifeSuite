<!-- 模板4: 雪天 -->
<template name="snowy">
  <view class="snowy weather-template">
    <image class="weather-icon" src="/res/icons/{{icon}}.svg" mode="aspectFit" />
    <view class="weather-info">
      <text class="weather-text">{{weather}}</text>
      <view class="temp-range">
