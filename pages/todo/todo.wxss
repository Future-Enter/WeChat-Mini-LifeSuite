/* 全局样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 30rpx 30rpx 120rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* 暗色模式适配 */
@media (prefers-color-scheme: dark) {
  .container {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }
}

/* 头部区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title-section {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #2d3436;
  margin-bottom: 10rpx;
  letter-spacing: -0.5rpx;
}

@media (prefers-color-scheme: dark) {
  .main-title {
    color: #f8f9fa;
  }
}

.sub-title {
  font-size: 24rpx;
  color: #636e72;
  font-weight: 400;
}

@media (prefers-color-scheme: dark) {
  .sub-title {
    color: #b2bec3;
  }
}

.date-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.current-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 5rpx;
}

@media (prefers-color-scheme: dark) {
  .current-date {
    color: #f8f9fa;
  }
}

.current-time {
  font-size: 22rpx;
  color: #636e72;
  font-weight: 400;
}

@media (prefers-color-scheme: dark) {
  .current-time {
    color: #b2bec3;
  }
}

/* 统计卡片 */
.stats-container {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.stats-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

@media (prefers-color-scheme: dark) {
  .stats-card {
    background: rgba(45, 52, 54, 0.7);
    border: 1rpx solid rgba(255, 255, 255, 0.1);
  }
}

.stats-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.stats-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.stats-icon.total {
  background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
  color: white;
}

.stats-icon.pending {
  background: linear-gradient(135deg, #fd79a8 0%, #e84393 100%);
  color: white;
}

.stats-icon.completed {
  background: linear-gradient(135deg, #00b894 0%, #00a085 100%);
  color: white;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 5rpx;
}

@media (prefers-color-scheme: dark) {
  .stats-number {
    color: #f8f9fa;
  }
}

.stats-label {
  font-size: 24rpx;
  color: #636e72;
  font-weight: 500;
}

@media (prefers-color-scheme: dark) {
  .stats-label {
    color: #b2bec3;
  }
}

/* 添加待办卡片 */
.add-todo-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

@media (prefers-color-scheme: dark) {
  .add-todo-card {
    background: rgba(45, 52, 54, 0.8);
    border: 1rpx solid rgba(255, 255, 255, 0.1);
  }
}

.add-todo-card:hover {
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
}

@media (prefers-color-scheme: dark) {
  .card-title {
    color: #f8f9fa;
  }
}

.priority-selector {
  display: flex;
  background: rgba(223, 230, 233, 0.5);
  border-radius: 10rpx;
  padding: 5rpx;
}

@media (prefers-color-scheme: dark) {
  .priority-selector {
    background: rgba(99, 110, 114, 0.3);
  }
}

.priority-option {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #636e72;
  border-radius: 8rpx;
  transition: all 0.2s ease;
  font-weight: 500;
}

@media (prefers-color-scheme: dark) {
  .priority-option {
    color: #b2bec3;
  }
}

.priority-option.active {
  background: white;
  color: #2d3436;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

@media (prefers-color-scheme: dark) {
  .priority-option.active {
    background: #0984e3;
    color: white;
  }
}

.priority-option[data-priority="1"].active {
  background: #00b894;
  color: white;
}

.priority-option[data-priority="2"].active {
  background: #0984e3;
  color: white;
}

.priority-option[data-priority="3"].active {
  background: #e17055;
  color: white;
}

.input-container {
  display: flex;
  align-items: center;
}

.todo-input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  background: rgba(223, 230, 233, 0.3);
  border-radius: 15rpx;
  font-size: 28rpx;
  color: #2d3436;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

@media (prefers-color-scheme: dark) {
  .todo-input {
    background: rgba(99, 110, 114, 0.2);
    color: #f8f9fa;
  }
}

.todo-input:focus {
  border-color: #74b9ff;
  background: rgba(116, 185, 255, 0.1);
}

.placeholder {
  color: #b2bec3;
  font-size: 28rpx;
}

@media (prefers-color-scheme: dark) {
  .placeholder {
    color: #636e72;
  }
}

.add-btn {
  width: 160rpx;
  height: 80rpx;
  margin-left: 20rpx;
  background: #dfe6e9;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
  padding: 0;
}

.add-btn.active {
  background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
  box-shadow: 0 6rpx 20rpx rgba(116, 185, 255, 0.4);
}

.add-btn.disabled {
  opacity: 0.6;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 300;
  color: #636e72;
  margin-right: 10rpx;
}

.add-btn.active .add-icon {
  color: white;
}

.add-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #636e72;
}

.add-btn.active .add-text {
  color: white;
}

.hover-effect {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 筛选和排序区域 */
.filter-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.filter-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: 12rpx;
  padding: 5rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

@media (prefers-color-scheme: dark) {
  .filter-tabs {
    background: rgba(45, 52, 54, 0.7);
  }
}

.filter-tab {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #636e72;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  position: relative;
  font-weight: 500;
}

@media (prefers-color-scheme: dark) {
  .filter-tab {
    color: #b2bec3;
  }
}

.filter-tab.active {
  background: white;
  color: #2d3436;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

@media (prefers-color-scheme: dark) {
  .filter-tab.active {
    background: #0984e3;
    color: white;
  }
}

.filter-badge {
  background: #dfe6e9;
  color: #636e72;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

@media (prefers-color-scheme: dark) {
  .filter-badge {
    background: rgba(99, 110, 114, 0.3);
    color: #b2bec3;
  }
}

.filter-tab.active .filter-badge {
  background: rgba(116, 185, 255, 0.2);
  color: #0984e3;
}

@media (prefers-color-scheme: dark) {
  .filter-tab.active .filter-badge {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }
}

.sort-options {
  display: flex;
  background: rgba(223, 230, 233, 0.5);
  border-radius: 10rpx;
  padding: 5rpx;
}

@media (prefers-color-scheme: dark) {
  .sort-options {
    background: rgba(99, 110, 114, 0.3);
  }
}

.sort-option {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #636e72;
  border-radius: 8rpx;
  transition: all 0.2s ease;
  font-weight: 500;
}

@media (prefers-color-scheme: dark) {
  .sort-option {
    color: #b2bec3;
  }
}

.sort-option.active {
  background: white;
  color: #2d3436;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

@media (prefers-color-scheme: dark) {
  .sort-option.active {
    background: #0984e3;
    color: white;
  }
}

/* 待办事项列表 */
.todo-list {
  height: calc(100vh - 700rpx);
  min-height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.todo-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 25rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #0984e3;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

@media (prefers-color-scheme: dark) {
  .todo-item {
    background: rgba(45, 52, 54, 0.8);
  }
}

.todo-item:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.todo-item.completed {
  opacity: 0.7;
  background: rgba(223, 230, 233, 0.5);
}

@media (prefers-color-scheme: dark) {
  .todo-item.completed {
    background: rgba(99, 110, 114, 0.3);
  }
}

.todo-item.completed .todo-text {
  text-decoration: line-through;
  color: #636e72;
}

@media (prefers-color-scheme: dark) {
  .todo-item.completed .todo-text {
    color: #b2bec3;
  }
}

/* 优先级指示器 */
.priority-indicator {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: #0984e3;
  border-radius: 8rpx 0 0 8rpx;
}

.todo-item.priority-1 .priority-indicator {
  background: #00b894;
}

.todo-item.priority-2 .priority-indicator {
  background: #0984e3;
}

.todo-item.priority-3 .priority-indicator {
  background: #e17055;
}

/* 复选框 */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid #dfe6e9;
  margin-right: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
  background: white;
}

@media (prefers-color-scheme: dark) {
  .checkbox {
    background: #2d3436;
    border-color: #636e72;
  }
}

.checkbox.checked {
  background: #00b894;
  border-color: #00b894;
  animation: checkAnim 0.4s ease;
}

@keyframes checkAnim {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.checkbox-inner {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkmark {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.5); }
  to { opacity: 1; transform: scale(1); }
}

/* 待办内容 */
.todo-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.todo-main {
  margin-bottom: 15rpx;
}

.todo-text {
  font-size: 32rpx;
  color: #2d3436;
  line-height: 1.4;
  word-break: break-word;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: block;
}

@media (prefers-color-scheme: dark) {
  .todo-text {
    color: #f8f9fa;
  }
}

.todo-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.priority-tag, .time-tag {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.priority-tag.priority-1 {
  background: rgba(0, 184, 148, 0.1);
  color: #00b894;
  border: 1rpx solid rgba(0, 184, 148, 0.3);
}

.priority-tag.priority-2 {
  background: rgba(9, 132, 227, 0.1);
  color: #0984e3;
  border: 1rpx solid rgba(9, 132, 227, 0.3);
}

.priority-tag.priority-3 {
  background: rgba(225, 112, 85, 0.1);
  color: #e17055;
  border: 1rpx solid rgba(225, 112, 85, 0.3);
}

.time-tag {
  background: rgba(223, 230, 233, 0.5);
  color: #636e72;
  border: 1rpx solid rgba(223, 230, 233, 0.8);
}

@media (prefers-color-scheme: dark) {
  .time-tag {
    background: rgba(99, 110, 114, 0.3);
    color: #b2bec3;
    border: 1rpx solid rgba(99, 110, 114, 0.5);
  }
}

/* 待办操作 */
.todo-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn.edit {
  background: rgba(116, 185, 255, 0.1);
  color: #0984e3;
  border: 1rpx solid rgba(116, 185, 255, 0.3);
}

.action-btn.delete {
  background: rgba(225, 112, 85, 0.1);
  color: #e17055;
  border: 1rpx solid rgba(225, 112, 85, 0.3);
}

.action-btn.edit:active, .action-btn.delete:active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  color: #2d3436;
  font-weight: 600;
  margin-bottom: 15rpx;
}

@media (prefers-color-scheme: dark) {
  .empty-title {
    color: #f8f9fa;
  }
}

.empty-subtitle {
  font-size: 26rpx;
  color: #636e72;
  line-height: 1.5;
  max-width: 400rpx;
}

@media (prefers-color-scheme: dark) {
  .empty-subtitle {
    color: #b2bec3;
  }
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  z-index: 100;
}

@media (prefers-color-scheme: dark) {
  .bottom-actions {
    background: rgba(45, 52, 54, 0.9);
    border: 1rpx solid rgba(255, 255, 255, 0.1);
  }
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 15rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  margin: 0 10rpx;
}

.bottom-btn.complete-all {
  background: linear-gradient(135deg, #00b894 0%, #00a085 100%);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(0, 184, 148, 0.4);
}

.bottom-btn.clear-completed {
  background: linear-gradient(135deg, #fd79a8 0%, #e84393 100%);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(253, 121, 168, 0.4);
}

.bottom-btn.disabled {
  opacity: 0.5;
  filter: grayscale(0.5);
  pointer-events: none;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
  font-weight: 300;
}

.btn-text {
  font-weight: 600;
}

/* 编辑模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
  pointer-events: none;
}

.modal.show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(5rpx);
}

.modal-content {
  background: white;
  width: 80%;
  max-width: 600rpx;
  border-radius: 20rpx;
  overflow: hidden;
  z-index: 1001;
  transform: translateY(50rpx);
  opacity: 0;
  transition: all 0.3s ease 0.1s;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

@media (prefers-color-scheme: dark) {
  .modal-content {
    background: #2d3436;
  }
}

.modal.show .modal-content {
  transform: translateY(0);
  opacity: 1;
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #dfe6e9;
}

@media (prefers-color-scheme: dark) {
  .modal-header {
    border-bottom-color: #636e72;
  }
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
}

@media (prefers-color-scheme: dark) {
  .modal-title {
    color: #f8f9fa;
  }
}

.modal-close {
  font-size: 40rpx;
  color: #636e72;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: #dfe6e9;
}

@media (prefers-color-scheme: dark) {
  .modal-close {
    color: #b2bec3;
  }
  
  .modal-close:active {
    background: #636e72;
  }
}

.modal-body {
  padding: 40rpx;
}

.modal-input {
  width: 100%;
  height: 100rpx;
  padding: 0 30rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
  font-size: 28rpx;
  color: #2d3436;
  border: 2rpx solid transparent;
  margin-bottom: 40rpx;
  transition: all 0.3s ease;
}

@media (prefers-color-scheme: dark) {
  .modal-input {
    background: rgba(99, 110, 114, 0.2);
    color: #f8f9fa;
  }
}

.modal-input:focus {
  border-color: #74b9ff;
  background: white;
}

@media (prefers-color-scheme: dark) {
  .modal-input:focus {
    background: #2d3436;
  }
}

.modal-priority {
  display: flex;
  align-items: center;
}

.modal-label {
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
  margin-right: 20rpx;
}

@media (prefers-color-scheme: dark) {
  .modal-label {
    color: #f8f9fa;
  }
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #dfe6e9;
}

@media (prefers-color-scheme: dark) {
  .modal-footer {
    border-top-color: #636e72;
  }
}

.modal-btn {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.modal-btn.cancel {
  color: #636e72;
  border-right: 1rpx solid #dfe6e9;
}

@media (prefers-color-scheme: dark) {
  .modal-btn.cancel {
    color: #b2bec3;
    border-right-color: #636e72;
  }
}

.modal-btn.cancel:active {
  background: #f8f9fa;
}

@media (prefers-color-scheme: dark) {
  .modal-btn.cancel:active {
    background: #636e72;
  }
}

.modal-btn.confirm {
  color: #0984e3;
  background: rgba(116, 185, 255, 0.1);
}

.modal-btn.confirm:active {
  background: rgba(116, 185, 255, 0.2);
}

/* 加载动画 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 2000;
}

@media (prefers-color-scheme: dark) {
  .loading {
    background: rgba(0, 0, 0, 0.7);
  }
}

.loading.show {
  opacity: 1;
  visibility: visible;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #dfe6e9;
  border-top-color: #0984e3;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}